// Car2Fix CRM — Prisma schema (Prisma 7)
// Connection URLs live OUTSIDE this file in v7:
//  - Runtime: lib/prisma.js builds a pg driver adapter from the POOLED
//    DATABASE_URL and passes it to the PrismaClient constructor.
//  - Migrations: prisma.config.js supplies the UNPOOLED DATABASE_URL_UNPOOLED
//    (migrate can't run over the PgBouncer pooler).
// Both env vars are provisioned by the Neon Vercel Marketplace integration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// A referral source that sends us customers — towing companies today, possibly
/// insurance adjusters or rental agencies later. Commission terms live here so
/// each referral can compute its payout at approval time.
model ReferralPartner {
  id             String   @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  type           String   @default("towing") // towing | insurance | rental | other
  commissionType String   @default("percent") // percent (of invoice) | flat (per referral)
  commissionRate Int      @default(10) // percent value (10 = 10%) or flat whole US dollars
  active         Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrals Referral[]

  @@index([active])
}

/// One referred customer/job. Lifecycle:
/// received -> invoice_uploaded -> approved -> paid, with rejected as a detour
/// (shop can re-attach a corrected invoice, returning it to invoice_uploaded).
/// Money fields are whole US dollars, matching Lead.value.
model Referral {
  id             String  @id @default(cuid())
  partnerId      String
  partner        ReferralPartner @relation(fields: [partnerId], references: [id])
  customerName   String
  customerPhone  String?
  vehicle        String?
  jobDescription String?
  shopType       String // 'mechanical' | 'body'
  status         String  @default("received") // received | invoice_uploaded | approved | rejected | paid

  invoiceNumber     String?
  invoiceAmount     Int? // final invoice total in whole US dollars
  invoiceUrl        String? // private Vercel Blob URL; served via /api/crm/referrals/[id]/invoice
  invoiceUploadedAt DateTime?

  commissionAmount Int? // whole US dollars, set at approval (computed from partner terms, admin may override)
  approvedAt       DateTime?
  rejectedReason   String?
  paidAt           DateTime?
  paidBy           String? // name of the person who handed the cash to the partner

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([partnerId])
  @@index([shopType])
  @@index([createdAt])
  @@index([approvedAt])
  @@index([paidAt])
}

/// Cash handed TO a shop to fund referral payouts. Reconciliation per shop:
/// sum(advances) - sum(paid commissions) = cash that should be in the drawer.
model CashAdvance {
  id        String   @id @default(cuid())
  shopType  String // 'mechanical' | 'body'
  amount    Int // whole US dollars
  note      String?
  createdAt DateTime @default(now())

  @@index([shopType])
  @@index([createdAt])
}

/// A sales lead captured from the website contact form or auto-created from an
/// inbound phone call (source 'phone_call'). The CRM board groups these by
/// `stage`; marketing moves them through the pipeline.
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  phoneE164 String? // normalized +1XXXXXXXXXX; the join key for matching RingCentral callers
  carModel  String
  issue     String
  shopType  String // 'mechanical' | 'body'
  source    String   @default("website_form") // website_form | phone_call | manual
  stage     String   @default("new") // new | contacted | estimate_sent | scheduled | in_service | completed | lost
  value     Int? // estimated job value in whole US dollars, editable in the CRM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calls Call[]

  @@index([stage])
  @@index([shopType])
  @@index([createdAt])
  @@index([phoneE164])
}

/// One phone call ingested from RingCentral (call-log sync cron and/or the
/// telephony webhook). RingCentral purges recordings after 90 days and call
/// logs after ~12 months, so this table plus the private Blob store is the
/// long-term system of record. Matched to a Lead by the customer's E.164 number.
model Call {
  id                 String  @id @default(cuid())
  // RingCentral call-log record id. Webhook-created stubs use
  // 'tsess:{telephonySessionId}' until the next sync merges the real record in.
  rcCallId           String  @unique
  sessionId          String?
  telephonySessionId String?
  direction          String // 'Inbound' | 'Outbound'
  fromNumber         String? // E.164 as reported by RingCentral
  fromName           String? // best-effort caller ID (often a city/state or 'WIRELESS CALLER')
  fromLocation       String?
  toNumber           String?
  shopType           String // 'mechanical' | 'body' — derived from the shop line the customer dialed
  result             String // RingCentral result: Accepted | Missed | Voicemail | Busy | No Answer | ...
  action             String?
  transport          String?
  startTime          DateTime
  durationSec        Int      @default(0)

  recordingRcId        String?
  recordingContentUri  String? // media.ringcentral.com download URL (valid ~90 days)
  recordingBlobUrl     String? // our private Blob copy — set once archived
  recordingContentType String?
  recordingError       String? // set when the download permanently failed; stops retries

  vmMessageUri       String? // message-store URI of the voicemail left on this call
  vmStatus           String? // null=pending | InProgress | Completed | NotAvailable | TimedOut
  vmTranscript       String?
  vmAudioBlobUrl     String?
  vmAudioContentType String?

  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id])
  leadAutoCreated Boolean  @default(false)
  alertedAt       DateTime? // missed-call/voicemail Telegram alert sent
  vmAlertedAt     DateTime? // follow-up alert with the voicemail transcript sent

  rcRaw     Json? // raw RingCentral record, kept for debugging a blind integration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([leadId])
  @@index([shopType])
  @@index([result])
  @@index([telephonySessionId])
}

/// Singleton cursor + advisory lock for the RingCentral call-log-sync endpoint.
model RcSyncState {
  id         String    @id @default("singleton")
  syncToken  String?
  lastSyncAt DateTime?
  lastError  String?
  lockedAt   DateTime? // set while a sync run is in flight; stale after 3 minutes
  updatedAt  DateTime  @updatedAt
}
