# Car2Fix environment variables
# DO NOT commit this file with real values! Copy to .env.local for local dev.

# --- Telegram lead notifications ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID_MECHANICAL=your_mechanical_shop_chat_id_here
TELEGRAM_CHAT_ID_BODYSHOP=your_bodyshop_chat_id_here

# --- Database (Neon Postgres via the Vercel Marketplace) ---
# Provisioned by the Neon integration, then synced locally with:
#   vercel env pull .env.local
# DATABASE_URL is the POOLED endpoint (host contains "-pooler") — used by the app at runtime.
# DATABASE_URL_UNPOOLED is the direct endpoint — used only by `prisma migrate`.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- CRM shared-team login (/crm) ---
# CRM_PASSWORD: the single password the marketing team enters at /crm/login.
# CRM_SESSION_SECRET: signs the session cookie. Generate with: openssl rand -base64 32
CRM_PASSWORD=choose_a_strong_shared_password
CRM_SESSION_SECRET=generate_with_openssl_rand_base64_32

# --- Optional ---
# Base URL used for the "Open in CRM" deep link in Telegram messages.
# Defaults to https://www.car2fix.com when unset.
# NEXT_PUBLIC_SITE_URL=https://www.car2fix.com
